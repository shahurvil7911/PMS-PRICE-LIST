{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "create-react-app"
    },
   "backend": {
  "root": "backend",
  "runtime": "python",
  "entrypoint": "server.py"
}
    }
  },
  "rewrites": [
    {
      "source": "/api(/.*)?",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
